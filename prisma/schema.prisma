generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             Int            @id @default(autoincrement())
  fullName       String
  jobTitle       String
  personalEmail  String         @unique
  contactNo      String
  hiringDate     DateTime
  reportingTo    String?
  konectaMail    String         @unique
  role           String         @default("EMPLOYEE")
  password       String
  departmentId   Int?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  assignedAssets Asset[]        @relation("AssetAssignment")
  notifications  Notification[] @relation("UserNotifications")
  tickets        Ticket[]       @relation("TicketRequester")
  department     Department?    @relation(fields: [departmentId], references: [id])
}

model Department {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  assets      Asset[]  @relation("DepartmentAssets")
  users       User[]
}

model InventoryItem {
  id             Int      @id @default(autoincrement())
  category       String
  brand          String
  model          String
  totalCount     Int      @default(0)
  availableCount Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  assets         Asset[]

  @@unique([category, brand, model])
}

model Asset {
  id               Int           @id @default(autoincrement())
  serialNumber     String        @unique
  price            Float?        @default(0)
  status           String        @default("IN_STOCK")
  notes            String?
  inventoryItemId  Int
  assignedToUserId Int?
  departmentId     Int?
  assignedDate     DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  department       Department?   @relation("DepartmentAssets", fields: [departmentId], references: [id])
  assignedToUser   User?         @relation("AssetAssignment", fields: [assignedToUserId], references: [id])
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id])
  maintenances     Maintenance[]
}

model Ticket {
  id                   Int                @id @default(autoincrement())
  recNumber            String             @unique
  status               String             @default("OPEN")
  issueDate            DateTime           @default(now())
  requesterName        String
  email                String
  priority             String             @default("LOW")
  issueImpact          String
  clientImpact         String?
  clientName           String?
  troubleshootingSteps String?
  resolution           String?
  resolutionDate       DateTime?
  category             String?
  usersImpact          String?
  requesterId          Int?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  requester            User?              @relation("TicketRequester", fields: [requesterId], references: [id])
  attachments          TicketAttachment[]
}

model TicketAttachment {
  id        Int      @id @default(autoincrement())
  filename  String
  filepath  String
  ticketId  Int
  createdAt DateTime @default(now())
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model Vendor {
  id            Int             @id @default(autoincrement())
  name          String          @unique
  contactPerson String
  email         String?
  phone         String?
  token         String          @unique @default(cuid())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  orders        PurchaseOrder[]
  vendorAssets  VendorAsset[]
}

model VendorAsset {
  id           Int      @id @default(autoincrement())
  category     String
  brand        String
  model        String
  serialNumber String   @unique
  status       String   @default("AVAILABLE")
  vendorId     Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  price        Float?   @default(0)
  vendor       Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model PurchaseOrder {
  id          Int      @id @default(autoincrement())
  orderNumber String   @unique
  status      String   @default("PENDING")
  category    String
  quantity    Int
  description String?
  totalAmount Float?   @default(0)
  vendorId    Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  vendor      Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  action     String
  details    String
  userEmail  String?
  entityType String?
  entityId   String?
  createdAt  DateTime @default(now())
}

model Notification {
  id        Int      @id @default(autoincrement())
  title     String
  message   String
  type      String   @default("INFO")
  isRead    Boolean  @default(false)
  userId    Int?
  createdAt DateTime @default(now())
  user      User?    @relation("UserNotifications", fields: [userId], references: [id])
}

model Maintenance {
  id           Int       @id @default(autoincrement())
  assetId      Int
  vendorName   String
  serialNumber String
  sendDate     DateTime  @default(now())
  returnDate   DateTime?
  status       String    @default("OUT_FOR_REPAIR")
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  asset        Asset     @relation(fields: [assetId], references: [id])
}

model Category {
  id     Int     @id @default(autoincrement())
  name   String  @unique
  fields String? // JSON array of custom field names
}
